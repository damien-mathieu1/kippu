{
  "name": "kippu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:docker": "docker-compose up -d",
    "dev:deps": "pnpm install",
    "dev:whatsapp-consumer": "pnpm --filter @kippu/whatsapp-consumer run dev",
    "dev:mail-consumer": "pnpm --filter @kippu/mail-consumer run dev",
    "dev:producer": "pnpm --filter @kippu/producer run dev",
    "dev:formatted-ticket-consumer": "pnpm --filter @kippu/formatted-ticket-consumer run dev",
    "dev:labelized-ticket-consumer": "pnpm --filter @kippu/labelized-ticket-consumer run dev",
    "dev": "concurrently \"pnpm run dev:whatsapp-consumer\" \"pnpm run dev:mail-consumer\" \"pnpm run dev:producer\" \"pnpm run dev:formatted-ticket-consumer\" \"pnpm run dev:labelized-ticket-consumer\"",
    "build": "pnpm -r run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
