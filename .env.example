#api url
VITE_API_URL=http://localhost:3000
# Kafka Configuration
KAFKA_BROKERS=localhost:9092,localhost:9094

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=messages
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Migration Configuration
# Set to false in production to disable automatic schema creation on startup
# Use 'pnpm migrate' instead for controlled migrations
AUTO_MIGRATE=true

# Discord Webhook Configuration
# Webhook URL to send alerts when processing errors occur
DISCORD_WEBHOOK_URL_ERROR=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_WEBHOOK_URL_TICKET=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Ollama Configuration (for formatted-ticket-consumer)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Producer Configuration
# Error rate for testing DLQ (0 = no errors, 1 = 100% errors)
ERROR_RATE=0.1
